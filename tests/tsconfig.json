{
	"compilerOptions": {
		"ignoreDeprecations": "6.0",
		"rootDir": ".",
		"outDir": "./dist",
		"module": "nodenext",
		"target": "esnext",
		"types": [],
		"baseUrl": ".",
		"paths": {
			"@e2e/*": [
				"./e2e/*"
			]
		},
		"sourceMap": true,
		"declaration": true,
		"declarationMap": true,
		"noUncheckedIndexedAccess": true,
		"exactOptionalPropertyTypes": false,
		"strict": true,
		"jsx": "react-jsx",
		"verbatimModuleSyntax": false,
		"isolatedModules": true,
		"noUncheckedSideEffectImports": true,
		"moduleDetection": "force",
		"skipLibCheck": true
	}
}