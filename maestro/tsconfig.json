{
	"extends": "expo/tsconfig.base",
	"compilerOptions": {
		"strict": true,
		"paths": {
			"@/*": [
				"./*"
			],
			"react-native-bottomsheet": [
				"../react-native-bottomsheet/src"
			],
			"react-native-bottomsheet/*": [
				"../react-native-bottomsheet/src/*"
			]
		}
	},
	"include": [
		"**/*.ts",
		"**/*.tsx",
		".expo/types/**/*.ts",
		"expo-env.d.ts"
	]
}